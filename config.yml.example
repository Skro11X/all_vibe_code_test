# Маппинг календарь → TG канал с контекстом
# Каждый календарь привязан к каналу, из которого берётся контекст для подготовки к встречам
calendar_channels:
  - calendar_name: "Рабочий"
    channel_id: -100xxxxxxxxxxxx
    context_messages_limit: 50
  - calendar_name: "Проект X"
    channel_id: -100yyyyyyyyyyyy
    context_messages_limit: 100

# Планировщик
scheduler:
  check_interval_minutes: 5
  meeting_prep_before_minutes: 15

# DeepSeek
deepseek:
  model: "deepseek-chat"
  max_tokens: 4096
  temperature: 0.7
